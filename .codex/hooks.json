{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "node .codex/hooks/mlua-session-start.js",
            "timeout": 120,
            "statusMessage": "Starting mLua LSP daemon"
          }
        ]
      }
    ]
  }
}
